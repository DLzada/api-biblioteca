
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Book {
  id        String   @id @default(uuid())
  title     String
  price     Float
  author    Author   @relation(fields: [authorId], references: [id])
  authorId  String
}

model Author {
  id    String @id @default(uuid())
  name  String
  books Book[]
}